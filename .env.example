# ── Core ──────────────────────────────────────────
APP_NAME="SimpleAd Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Bucharest
APP_URL=https://manager.simplead.ro
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────
LOG_CHANNEL=production
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

# ── Database (PostgreSQL via PgBouncer) ───────────
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=simplead_manager
DB_USERNAME=simplead
DB_PASSWORD=
DB_SSLMODE=require
# Use 'prefer' for local development, 'require' for production

# ── Session ───────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=manager.simplead.ro
SESSION_SECURE_COOKIE=true

# ── Broadcasting & Filesystem ─────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queue & Cache ─────────────────────────────────
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_DRIVER=redis
CACHE_LOCKS_DRIVER=redis

# ── Redis ─────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Trusted Proxies ──────────────────────────────
# Docker bridge network only (no Cloudflare):
TRUSTED_PROXIES=172.18.0.0/16
# With Cloudflare proxy enabled, use:
# TRUSTED_PROXIES=172.18.0.0/16,173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# ── Mail (Gmail SMTP) ────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# ── Backup Encryption ────────────────────────────
BACKUP_ENCRYPTION_KEY=

# ── Gotenberg (PDF generation) ────────────────────
GOTENBERG_URL=http://gotenberg:3000

# ── Google PageSpeed API ──────────────────────────
PAGESPEED_API_KEY=

# ── Horizon ───────────────────────────────────────
HORIZON_PREFIX=simplead_horizon:

# ── Vite ──────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
