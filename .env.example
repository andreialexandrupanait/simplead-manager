# =============================================================================
# SimpleAd Manager — environment template
# =============================================================================
# Copy to `.env` and fill the REQUIRED values. Vars not listed here have safe
# defaults in config/*.php; the ones below are either required (no default) or
# the operationally important knobs. Never commit a real `.env`.
# Full DR / install steps: docs/runbook-instalare.md
# =============================================================================

# --- Application (REQUIRED) --------------------------------------------------
APP_NAME="SimpleAd Manager"
APP_ENV=production
# Generate with: php artisan key:generate  (base64:...)
APP_KEY=
APP_DEBUG=false
APP_URL=https://manager.simplead.ro
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
# Staging installs: true relaxes prod-only guards where applicable.
STAGING_MODE=false

# --- Trusted proxies ---------------------------------------------------------
# Behind Docker/nginx/Cloudflare. Comma-separated IPs/CIDRs, or "*" to trust all
# forwarding proxies (only safe when nothing untrusted can reach the app port).
TRUSTED_PROXIES=127.0.0.1

# --- Database: PostgreSQL via PgBouncer (REQUIRED) ---------------------------
# App traffic goes through PgBouncer (transaction pooling). Migrations/DDL use
# the pgsql_direct connection (DB_DIRECT_*) to bypass the pooler — see deploy.sh.
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=simplead
DB_USERNAME=simplead
DB_PASSWORD=
# Direct-to-Postgres (no pooler) for migrations. In prod compose these are
# injected as DB_DIRECT_HOST=pgsql / DB_DIRECT_PORT=5432.
DB_DIRECT_HOST=pgsql
DB_DIRECT_PORT=5432

# --- Redis (REQUIRED) — cache, queues, sessions, Horizon ---------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

# --- Cache / session / queue -------------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Locks that guard destructive site ops must survive Redis eviction — keep on DB.
SITE_OPERATION_LOCK_STORE=database
QUEUE_CONNECTION=redis

# --- Horizon worker counts (per supervisor) ----------------------------------
# Tune to host RAM. Backups are the memory hog; see docker-compose.prod.yml
# horizon memory note before raising HORIZON_BACKUP_WORKERS.
HORIZON_GENERAL_WORKERS=3
HORIZON_SYNC_WORKERS=3
HORIZON_NOTIFICATION_WORKERS=3
HORIZON_BACKUP_WORKERS=2
HORIZON_UPTIME_WORKERS=2
HORIZON_INCIDENT_RESPONSE_WORKERS=2

# --- Mail (REQUIRED for notifications / client emails) -----------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@simplead.ro
MAIL_FROM_NAME="${APP_NAME}"
# Alternatively use Resend instead of SMTP:
# MAIL_MAILER=resend
# RESEND_KEY=

# --- Logging -----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info
LOG_DAILY_DAYS=30

# --- Backups (REQUIRED) ------------------------------------------------------
# Symmetric key for backup encryption. Generate 32 random bytes, base64:
#   php -r "echo base64_encode(random_bytes(32));"
# Losing/rotating this makes existing encrypted backups unrecoverable.
BACKUP_ENCRYPTION_KEY=

# --- Offsite backup storage: S3-compatible (optional but recommended) --------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Offsite backup storage: Dropbox (optional) ------------------------------
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# --- Google OAuth: SSO login + Search Console / Analytics (optional) ---------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SSO_REDIRECT_URI=/auth/google/callback

# --- Cloudflare (optional — zone purge, DNS) ---------------------------------
# Per-account API token is stored per-integration in the DB, not here.
CLOUDFLARE_API_URL=https://api.cloudflare.com/client/v4

# --- PageSpeed Insights (optional — higher quota) ----------------------------
PAGESPEED_API_KEY=

# --- Gotenberg (REQUIRED for PDF reports) ------------------------------------
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_TIMEOUT=120

# --- Anthropic / AI ----------------------------------------------------------
# Required for the SEO/Audit AI fix generation (Faza D) and, if enabled, AI
# incident response. Leave empty to keep AI features off.
ANTHROPIC_API_KEY=
INCIDENT_RESPONSE_ENABLED=false
INCIDENT_RESPONSE_MODEL=claude-sonnet-4-5-20250929

# --- Slack notifications (optional) ------------------------------------------
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# --- Misc integrations (optional) --------------------------------------------
UNSPLASH_ACCESS_KEY=
# Uptime scheduler dead-man's-switch ping (e.g. healthchecks.io URL).
SCHEDULER_HEARTBEAT_URL=

# --- SSRF guard --------------------------------------------------------------
# Extra hosts the app may reach besides the connected sites (comma-separated).
SSRF_ALLOWED_HOSTS=
