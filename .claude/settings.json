{
  "permissions": {
    "deny": [
      "Bash(cat **/.env*)",
      "Bash(cat *.pem)",
      "Bash(cat *credentials*)",
      "Bash(echo * > .env*)",
      "Bash(printf * > .env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-env-files.sh"
          }
        ]
      }
    ]
  }
}
