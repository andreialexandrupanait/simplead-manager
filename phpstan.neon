includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/
    level: 5
    ignoreErrors:
        # Livewire magic properties
        - '#Access to an undefined property App\\Livewire\\#'
    excludePaths:
        - app/Console/Commands/MigrateReportFiles.php
