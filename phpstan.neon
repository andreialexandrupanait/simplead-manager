includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    parallel:
        # Small jobs + worker recycling keep peak memory bounded (a single
        # process accumulated >6GB analysing the whole app and never finished).
        maximumNumberOfProcesses: 2
        jobSize: 8
        processTimeout: 600.0
    paths:
        - app/
    level: 5
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Livewire magic properties
        - '#Access to an undefined property App\\Livewire\\#'
